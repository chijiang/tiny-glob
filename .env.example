# 复制为 .env 并填入值(Next.js 与 Prisma CLI 都读取 .env)。

# ===== 数据库 =====
# PostgreSQL 连接串。本地可先用 Docker:docker run --name tinyglob-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=tinyglob -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tinyglob?schema=public"

# ===== Auth =====
# JWT 签名密钥。本地生成:openssl rand -hex 32
AUTH_SECRET="replace-with-openssl-rand-hex-32"

# ===== LLM(OpenAI 兼容;支持 OpenAI / DeepSeek / 智谱 GLM / OpenRouter / 本地 Ollama 等)=====
# API Key(必填)
LLM_API_KEY=sk-your-key-here

# Base URL(可选;留空走 OpenAI 官方)。常见示例:
#   OpenRouter https://openrouter.ai/api/v1
#   DeepSeek   https://api.deepseek.com/v1
#   智谱 GLM   https://open.bigmodel.cn/api/paas/v4
#   本地 Ollama http://localhost:11434/v1
LLM_BASE_URL=

# 模型名(必填)。例:gpt-4o-mini / deepseek-chat / glm-4-flash / google/gemini-3.1-flash-lite
LLM_MODEL=gpt-4o-mini
